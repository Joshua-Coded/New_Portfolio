# YouTube API — server-side only (no NEXT_PUBLIC prefix keeps the key private)
# Get your API key at: https://console.developers.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Your YouTube channel ID (found in YouTube Studio > Settings > Channel > Basic Info)
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here

# Contact Form — powered by Formspree (free at https://formspree.io)
# 1. Sign up at formspree.io
# 2. Create a new form
# 3. Copy the form ID (the part after /f/ in your form endpoint)
NEXT_PUBLIC_FORMSPREE_FORM_ID=your_formspree_form_id_here
